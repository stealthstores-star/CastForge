{%- comment -%} "As recommended by" social proof strip. {% render 'featured-in-strip' %} {%- endcomment -%}
<div class="cf-featured-in">
  <div class="cf-container">
    <span class="cf-featured-in__label">AS RECOMMENDED BY</span>
    <div class="cf-featured-in__logos">
      <span class="cf-featured-in__logo cf-fi--bold">TABLETOP<em>GAMING</em></span>
      <span class="cf-featured-in__logo cf-fi--serif">Wargamer</span>
      <span class="cf-featured-in__logo cf-fi--mono">r/minipainting</span>
      <span class="cf-featured-in__logo cf-fi--mag">MiniWar <em>MAGAZINE</em></span>
      <span class="cf-featured-in__logo cf-fi--heavy">RESIN REBELS<em>Podcast</em></span>
    </div>
  </div>
</div>
<style>
.cf-featured-in{border-top:1px solid var(--cf-border,#222);border-bottom:1px solid var(--cf-border,#222);padding:14px 0;background:var(--cf-bg,#0a0a0a);}
.cf-featured-in .cf-container{display:flex;align-items:center;gap:24px;overflow-x:auto;}
.cf-featured-in__label{font-size:9px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--cf-text-muted,#888);white-space:nowrap;flex-shrink:0;}
.cf-featured-in__logos{display:flex;align-items:center;gap:32px;flex:1;justify-content:center;}
.cf-featured-in__logo{font-size:14px;color:var(--cf-text-muted,#888);opacity:0.5;white-space:nowrap;letter-spacing:1px;text-transform:uppercase;}
.cf-featured-in__logo em{font-style:normal;font-weight:300;opacity:0.7;}
.cf-fi--bold{font-weight:800;font-size:14px;}
.cf-fi--serif{font-family:Georgia,'Times New Roman',serif;font-weight:600;font-style:italic;letter-spacing:2px;font-size:15px;}
.cf-fi--mono{font-family:'SFMono-Regular',Consolas,monospace;font-weight:400;text-transform:none;font-size:13px;}
.cf-fi--mag{font-weight:700;font-size:14px;}
.cf-fi--mag em{font-size:10px;letter-spacing:3px;}
.cf-fi--heavy{font-weight:900;letter-spacing:3px;font-size:12px;}
.cf-fi--heavy em{font-weight:400;letter-spacing:1px;font-size:10px;margin-left:4px;}
@media(max-width:768px){.cf-featured-in__logos{gap:18px;}.cf-featured-in__logo{font-size:11px;}}
</style>
