{%- comment -%}
  Sticky Help Button — bottom-right floating button.
  {% render 'help-button' %}

  - Orange circle, 56px, SVG question-mark icon
  - Fixed position: bottom 24px, right 24px, z-index 90
  - Click opens a help modal with 4 navigation links
  - Click outside the modal panel closes it
  - Fully self-contained: CSS + JS inline
{%- endcomment -%}

<style>
  /* ── Help Button ── */
  .cf-help-btn {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 90;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #E86C2C;
    border: none;
    cursor: pointer;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    padding: 0;
  }
  .cf-help-btn:hover {
    transform: scale(1.08);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);
  }
  .cf-help-btn:active {
    transform: scale(0.96);
  }
  .cf-help-btn svg {
    width: 28px;
    height: 28px;
    fill: #fff;
  }

  /* ── Modal Overlay ── */
  .cf-help-overlay {
    position: fixed;
    inset: 0;
    z-index: 91;
    background: rgba(0, 0, 0, 0.4);
    display: none;
    align-items: flex-end;
    justify-content: flex-end;
    padding: 24px;
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .cf-help-overlay.cf-help-visible {
    display: flex;
    opacity: 1;
  }

  /* ── Modal Panel ── */
  .cf-help-panel {
    background: #fff;
    border-radius: 16px;
    width: 300px;
    max-width: calc(100vw - 48px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.2);
    padding: 0;
    margin-bottom: 68px;
    transform: translateY(16px);
    transition: transform 0.25s ease;
    overflow: hidden;
  }
  .cf-help-overlay.cf-help-visible .cf-help-panel {
    transform: translateY(0);
  }

  .cf-help-panel__header {
    padding: 20px 24px 12px;
    border-bottom: 1px solid #f0f0f0;
  }
  .cf-help-panel__header h3 {
    margin: 0;
    font-size: 16px;
    font-weight: 700;
    color: #1a1a1a;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }
  .cf-help-panel__header p {
    margin: 4px 0 0;
    font-size: 13px;
    color: #888;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  .cf-help-panel__links {
    list-style: none;
    margin: 0;
    padding: 8px 0;
  }
  .cf-help-panel__links li {
    margin: 0;
  }
  .cf-help-panel__links a {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 24px;
    text-decoration: none;
    color: #1a1a1a;
    font-size: 14px;
    font-weight: 500;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    transition: background 0.15s ease;
  }
  .cf-help-panel__links a:hover {
    background: #fdf4ee;
  }
  .cf-help-panel__links a svg {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    fill: #E86C2C;
  }
  .cf-help-panel__links a span {
    flex: 1;
  }
  .cf-help-panel__links a .cf-help-arrow {
    fill: #ccc;
    width: 14px;
    height: 14px;
  }
</style>

<!-- Help Button -->
<button class="cf-help-btn" id="cfHelpBtn" aria-label="Help" type="button">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm2.07-7.75l-.9.92C13.45 12.9 13 13.5 13 15h-2v-.5c0-1.1.45-2.1 1.17-2.83l1.24-1.26c.37-.36.59-.86.59-1.41 0-1.1-.9-2-2-2s-2 .9-2 2H8c0-2.21 1.79-4 4-4s4 1.79 4 4c0 .88-.36 1.68-.93 2.25z"/>
  </svg>
</button>

<!-- Help Modal -->
<div class="cf-help-overlay" id="cfHelpOverlay">
  <div class="cf-help-panel" id="cfHelpPanel">
    <div class="cf-help-panel__header">
      <h3>Need a hand?</h3>
      <p>Quick links to help you find what you need</p>
    </div>
    <ul class="cf-help-panel__links">
      <li>
        <a href="/pages/scale-guide">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M6 2c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6H6zm7 7V3.5L18.5 9H13zm-4 4h8v2H9v-2zm0 4h5v2H9v-2z"/></svg>
          <span>Browse by Scale</span>
          <svg class="cf-help-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg>
        </a>
      </li>
      <li>
        <a href="/collections/all">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M4 10h12v2H4v-2zm0-4h16v2H4V6zm0 8h8v2H4v-2zm10 0l4 4 4-4h-8z"/></svg>
          <span>Browse by Theme</span>
          <svg class="cf-help-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg>
        </a>
      </li>
      <li>
        <a href="/collections/best-sellers">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
          <span>Show me popular</span>
          <svg class="cf-help-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg>
        </a>
      </li>
      <li>
        <a href="/collections/all?q=beginner">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 3L1 9l4 2.18v6L12 21l7-3.82v-6l2-1.09V17h2V9L12 3zm6.82 6L12 12.72 5.18 9 12 5.28 18.82 9zM17 15.99l-5 2.73-5-2.73v-3.72L12 15l5-2.73v3.72z"/></svg>
          <span>Show me beginner-friendly</span>
          <svg class="cf-help-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg>
        </a>
      </li>
    </ul>
  </div>
</div>

<script>
(function() {
  'use strict';

  var btn = document.getElementById('cfHelpBtn');
  var overlay = document.getElementById('cfHelpOverlay');
  var panel = document.getElementById('cfHelpPanel');

  if (!btn || !overlay || !panel) return;

  function openHelp() {
    overlay.style.display = 'flex';
    /* Force reflow before adding visible class for transition */
    overlay.offsetHeight;
    overlay.classList.add('cf-help-visible');
    btn.style.display = 'none';
  }

  function closeHelp() {
    overlay.classList.remove('cf-help-visible');
    btn.style.display = 'flex';
    /* Wait for transition to finish, then hide overlay */
    setTimeout(function() {
      if (!overlay.classList.contains('cf-help-visible')) {
        overlay.style.display = 'none';
      }
    }, 260);
  }

  btn.addEventListener('click', function(e) {
    e.preventDefault();
    e.stopPropagation();
    openHelp();
  });

  /* Click outside the panel closes modal */
  overlay.addEventListener('click', function(e) {
    if (!panel.contains(e.target)) {
      closeHelp();
    }
  });

  /* Escape key closes */
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && overlay.classList.contains('cf-help-visible')) {
      closeHelp();
    }
  });
})();
</script>
