{%- comment -%} Reusable product card. Usage: {% render 'product-card', product: product %} {%- endcomment -%}
<a href="{{ product.url }}" class="cf-pcard">
  <div class="cf-pcard__img">
    {%- if product.featured_image -%}
      <img src="{{ product.featured_image | image_url: width: 500 }}" alt="{{ product.title }}" width="500" height="500" loading="lazy">
    {%- endif -%}
    {%- comment -%} Scale badge {%- endcomment -%}
    {%- for tag in product.tags -%}
      {%- if tag contains 'scale:' -%}
        <span class="cf-pcard__badge">{{ tag | remove: 'scale:' | replace: '-', '/' }}</span>
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}
    <div class="cf-pcard__hover">
      <span class="cf-pcard__quick">Quick View</span>
    </div>
  </div>
  <div class="cf-pcard__info">
    <h3 class="cf-pcard__title">{{ product.title | truncate: 60 }}</h3>
    <div class="cf-pcard__prices">
      <span class="cf-pcard__price">{{ product.price | money }}</span>
      {%- if product.compare_at_price > product.price -%}
        <span class="cf-pcard__was">{{ product.compare_at_price | money }}</span>
        {%- assign saved = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
        <span class="cf-pcard__save">-{{ saved }}%</span>
      {%- endif -%}
    </div>
    {%- if product.available -%}
      {%- if product.selected_or_first_available_variant.inventory_quantity <= 5 and product.selected_or_first_available_variant.inventory_quantity > 0 -%}
        <span class="cf-pcard__stock cf-pcard__stock--low">Only {{ product.selected_or_first_available_variant.inventory_quantity }} left</span>
      {%- endif -%}
    {%- else -%}
      <span class="cf-pcard__stock cf-pcard__stock--out">Sold out</span>
    {%- endif -%}
  </div>
</a>

<style>
.cf-pcard{display:block;background:var(--cf-bg-card,#141414);border:1px solid var(--cf-border,#222);border-radius:8px;overflow:hidden;text-decoration:none;transition:all 0.25s;}
.cf-pcard:hover{border-color:var(--cf-accent,#FF6B1A);transform:translateY(-3px);box-shadow:0 8px 24px rgba(255,107,26,0.15);}
.cf-pcard__img{position:relative;aspect-ratio:1;overflow:hidden;background:#111;}
.cf-pcard__img img{width:100%;height:100%;object-fit:cover;transition:transform 0.4s;}
.cf-pcard:hover .cf-pcard__img img{transform:scale(1.06);}
.cf-pcard__badge{position:absolute;top:8px;left:8px;background:rgba(0,0,0,0.7);color:#fff;font-size:11px;font-weight:700;padding:3px 8px;border-radius:4px;font-family:var(--cf-font-body);}
.cf-pcard__hover{position:absolute;inset:0;display:flex;align-items:flex-end;justify-content:center;padding-bottom:12px;opacity:0;transition:opacity 0.25s;background:linear-gradient(to top,rgba(0,0,0,0.5),transparent 40%);}
.cf-pcard:hover .cf-pcard__hover{opacity:1;}
.cf-pcard__quick{background:var(--cf-accent);color:#fff;font-size:12px;font-weight:600;padding:8px 20px;border-radius:6px;font-family:var(--cf-font-body);text-transform:uppercase;letter-spacing:0.5px;}
.cf-pcard__info{padding:10px 12px 12px;}
.cf-pcard__title{font-family:var(--cf-font-body);font-size:13px;font-weight:500;color:var(--cf-text,#e8e8e8);line-height:1.4;margin:0 0 6px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;}
.cf-pcard__prices{display:flex;align-items:baseline;gap:6px;}
.cf-pcard__price{font-family:var(--cf-font-display);font-size:17px;color:var(--cf-accent);}
.cf-pcard__was{font-size:12px;color:var(--cf-text-muted);text-decoration:line-through;}
.cf-pcard__save{font-size:11px;color:#22c55e;font-weight:600;background:rgba(34,197,94,0.1);padding:1px 5px;border-radius:3px;}
.cf-pcard__stock{font-size:11px;margin-top:4px;display:block;}
.cf-pcard__stock--low{color:#ef4444;}
.cf-pcard__stock--out{color:var(--cf-text-muted);}
@media(max-width:768px){.cf-pcard__hover{display:none;}.cf-pcard__title{font-size:12px;}}
</style>
