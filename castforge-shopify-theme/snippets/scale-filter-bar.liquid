<div class="cf-scale-bar">
  <div class="cf-container">
    <div class="cf-scale-bar__inner">
      <span class="cf-scale-bar__label">Scale</span>
      <div class="cf-scale-bar__track">
        <div class="cf-scale-bar__pills">
          {%- assign all_scales = "1/6,1/9,1/10,1/12,1/16,1/18,1/20,1/24,1/32,1/35,1/43,1/48,1/56,1/64,1/72,1/76,1/87,1/100,1/144,1/160,1/200,1/220,1/285,1/300,1/350,1/700,120mm,90mm,75mm,54mm,28mm,25mm,20mm,15mm,10mm" | split: "," -%}
          {%- for scale in all_scales -%}
            {%- assign slug = scale | replace: '/', '-' | downcase -%}
            <a href="/collections/all/{{ slug }}" class="cf-scale-pill">{{ scale }}</a>
          {%- endfor -%}
        </div>
        <div class="cf-scale-bar__fade"></div>
      </div>
    </div>
  </div>
</div>

<style>
.cf-scale-bar { padding: 14px 0; background: var(--cf-bg-card, #141414); border-bottom: 1px solid var(--cf-border, #222); }
.cf-scale-bar__inner { display: flex; align-items: center; gap: 14px; }
.cf-scale-bar__label { font-family: var(--cf-font-body); font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; color: var(--cf-accent, #FF6B1A); white-space: nowrap; flex-shrink: 0; }
.cf-scale-bar__track { position: relative; flex: 1; overflow: hidden; }
.cf-scale-bar__pills { display: flex; gap: 6px; overflow-x: auto; scroll-snap-type: x proximity; scrollbar-width: none; -webkit-overflow-scrolling: touch; padding-right: 40px; }
.cf-scale-bar__pills::-webkit-scrollbar { display: none; }
.cf-scale-pill { display: inline-flex; align-items: center; padding: 5px 14px; border: 1px solid var(--cf-border, #222); border-radius: 16px; font-family: var(--cf-font-body); font-size: 12px; font-weight: 600; color: var(--cf-text, #e8e8e8); text-decoration: none; white-space: nowrap; flex-shrink: 0; scroll-snap-align: start; transition: all 0.15s; }
.cf-scale-pill:hover { background: var(--cf-accent, #FF6B1A); border-color: var(--cf-accent); color: #fff; }
.cf-scale-bar__fade { position: absolute; top: 0; right: 0; width: 48px; height: 100%; background: linear-gradient(to right, transparent, var(--cf-bg-card, #141414)); pointer-events: none; }
</style>
