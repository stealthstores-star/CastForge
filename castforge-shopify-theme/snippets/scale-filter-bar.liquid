{%- comment -%} DEBUG VERSION — shows raw data so we can diagnose {%- endcomment -%}
<div style="background:#ff0;color:#000;padding:12px;font-family:monospace;font-size:11px;white-space:pre-wrap;">
DEBUG scale-filter-bar
template: {{ template }}
template.name: {{ template.name }}
collection.handle: {{ collection.handle | default: 'NONE' }}
collection.id: {{ collection.id | default: 'NONE' }}
collection.url: {{ collection.url | default: 'NONE' }}
collection.products_count: {{ collection.products_count | default: 'NONE' }}
collection.all_tags.size: {{ collection.all_tags.size | default: '0' }}
collection.tags.size: {{ collection.tags.size | default: '0' }}
current_tags: {{ current_tags | join: ',' | default: 'NONE' }}

--- first 20 all_tags ---
{%- for tag in collection.all_tags limit: 20 -%}
  {{ tag }}
{% endfor -%}

--- scale-prefixed from all_tags ---
{%- for tag in collection.all_tags -%}
  {%- if tag contains 'scale:' -%}{{ tag }} {%- endif -%}
{%- endfor -%}
</div>
