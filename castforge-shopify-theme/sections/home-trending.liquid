<section class="cf-trending">
  <div class="cf-container">
    <h2 class="cf-section-title">Trending Now</h2>
    <div class="cf-trending__scroll">
      {% assign trending = collections['best-sellers'] | default: collections['all'] %}
      {% for product in trending.products limit: 8 %}
        <a href="{{ product.url }}" class="cf-product-card">
          <div class="cf-product-card__img">
            {% if product.featured_image %}
              <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title }}" width="400" height="400" loading="lazy">
            {% endif %}
          </div>
          <h3 class="cf-product-card__title">{{ product.title | truncate: 55 }}</h3>
          <span class="cf-product-card__price">{{ product.price | money }}</span>
        </a>
      {% endfor %}
    </div>
    <div class="cf-trending__cta">
      <a href="/collections/all" class="cf-btn cf-btn--outline">View All {{ collections['all'].products_count | default: '13,000' }}+ Models</a>
    </div>
  </div>
</section>

<style>
.cf-trending { padding: 64px 0; border-top: 1px solid var(--cf-border); }
.cf-trending__scroll {
  display: flex;
  gap: 20px;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  padding-bottom: 8px;
  scrollbar-width: thin;
}
.cf-trending__scroll .cf-product-card {
  min-width: 240px;
  max-width: 280px;
  flex-shrink: 0;
  scroll-snap-align: start;
}
.cf-trending__cta { text-align: center; margin-top: 32px; }
</style>

{% schema %}
{ "name": "Trending Now", "tag": "section" }
{% endschema %}
