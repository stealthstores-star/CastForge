<section class="cf-section">
  <div class="cf-container">
    <p class="cf-eyebrow">Popular Right Now</p>
    <h2 class="cf-h2">Trending Models</h2>
    <div class="cf-trending__wrap">
      <button class="cf-trending__arrow cf-trending__arrow--l" id="cf-tl" aria-label="Left">‹</button>
      <div class="cf-trending__scroll" id="cf-ts">
        {%- assign tc = collections['best-sellers'] -%}
        {%- if tc == blank or tc.products_count == 0 -%}{%- assign tc = collections['all'] -%}{%- endif -%}
        {%- for product in tc.products limit: 8 -%}
          <div class="cf-trending__card">{% render 'product-card', product: product %}</div>
        {%- endfor -%}
      </div>
      <button class="cf-trending__arrow cf-trending__arrow--r" id="cf-tr" aria-label="Right">›</button>
    </div>
    <div style="text-align:center;margin-top:32px;">
      <a href="/collections/all" class="cf-btn cf-btn--outline">View All {{ collections['all'].products_count | default: '13,000' }}+ Models</a>
    </div>
  </div>
</section>
<style>
.cf-trending__wrap{position:relative;}
.cf-trending__scroll{display:flex;gap:16px;overflow-x:auto;scroll-snap-type:x mandatory;scrollbar-width:none;-webkit-overflow-scrolling:touch;padding:4px 0 8px;}
.cf-trending__scroll::-webkit-scrollbar{display:none;}
.cf-trending__card{min-width:220px;max-width:260px;flex-shrink:0;scroll-snap-align:start;}
.cf-trending__arrow{position:absolute;top:50%;transform:translateY(-80%);width:40px;height:40px;border-radius:50%;background:var(--cf-bg-card);border:1px solid var(--cf-border);color:var(--cf-text);font-size:24px;cursor:pointer;z-index:2;display:flex;align-items:center;justify-content:center;transition:all 0.2s;}
.cf-trending__arrow:hover{border-color:var(--cf-accent);color:var(--cf-accent);}
.cf-trending__arrow--l{left:-8px;}.cf-trending__arrow--r{right:-8px;}
@media(max-width:768px){.cf-trending__arrow{display:none;}.cf-trending__card{min-width:180px;}}
</style>
<script>
(function(){const s=document.getElementById('cf-ts');document.getElementById('cf-tl')?.addEventListener('click',()=>s.scrollBy({left:-280,behavior:'smooth'}));document.getElementById('cf-tr')?.addEventListener('click',()=>s.scrollBy({left:280,behavior:'smooth'}));})();
</script>
{% schema %}
{ "name": "Trending Now", "tag": "section" }
{% endschema %}
