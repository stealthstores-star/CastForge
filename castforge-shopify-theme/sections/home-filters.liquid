<section class="cf-section cf-section--alt">
  <div class="cf-container" style="text-align:center;">
    <p class="cf-eyebrow">Browse by Theme</p>
    <h2 class="cf-h2">Find Your Niche</h2>
    <div style="display:flex;flex-wrap:wrap;gap:10px;justify-content:center;">
      {%- assign themes = "WWII Military,Modern Warfare,Fantasy,Sci-Fi,Anime & Manga,Historical,Cars & Vehicles" | split: "," -%}
      {%- assign links = "scale-military-vehicles,wargaming-infantry,fantasy-warriors,scifi-figures,anime-characters,wargaming-heroes-characters,scale-cars-motorcycles" | split: "," -%}
      {%- for theme in themes -%}
        <a href="/collections/{{ links[forloop.index0] }}" class="cf-pill">{{ theme }}</a>
      {%- endfor -%}
    </div>
  </div>
</section>
<style>
.cf-pill{display:inline-flex;align-items:center;padding:10px 24px;border:1px solid var(--cf-border);border-radius:24px;font-family:var(--cf-font-body);font-size:14px;font-weight:500;color:var(--cf-text);text-decoration:none;white-space:nowrap;transition:all 0.2s;}
.cf-pill:hover{background:var(--cf-accent);border-color:var(--cf-accent);color:#fff;}
@media(max-width:768px){.cf-pill{padding:8px 16px;font-size:13px;}}
</style>
{% schema %}
{ "name": "Theme Filters", "tag": "section" }
{% endschema %}
