<section class="cf-filters">
  <div class="cf-container">
    <div class="cf-filters__group">
      <h3 class="cf-filters__label">Shop by Scale</h3>
      <div class="cf-filters__pills">
        {% assign scales = "1/35,1/72,1/24,1/16,1/10,75mm,28mm" | split: "," %}
        {% for scale in scales %}
          <a href="/collections/all?q={{ scale | url_encode }}" class="cf-pill">{{ scale }}</a>
        {% endfor %}
      </div>
    </div>
    <div class="cf-filters__group">
      <h3 class="cf-filters__label">Shop by Theme</h3>
      <div class="cf-filters__pills">
        {% assign themes = "WWII,Modern Military,Fantasy,Sci-Fi,Anime,Historical,Cars" | split: "," %}
        {% assign theme_links = "scale-military-vehicles,wargaming-infantry,fantasy-warriors,scifi-figures,anime-characters,wargaming-heroes-characters,scale-cars-motorcycles" | split: "," %}
        {% for theme in themes %}
          <a href="/collections/{{ theme_links[forloop.index0] }}" class="cf-pill">{{ theme }}</a>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<style>
.cf-filters { padding: 48px 0; border-top: 1px solid var(--cf-border); }
.cf-filters__group { margin-bottom: 24px; text-align: center; }
.cf-filters__group:last-child { margin-bottom: 0; }
.cf-filters__label {
  font-family: var(--cf-font-body);
  font-size: 13px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--cf-text-muted);
  margin-bottom: 12px;
}
.cf-filters__pills { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; }
.cf-pill {
  padding: 8px 18px;
  border: 1px solid var(--cf-border);
  border-radius: 20px;
  font-family: var(--cf-font-body);
  font-size: 13px;
  font-weight: 500;
  color: var(--cf-text);
  text-decoration: none;
  transition: all 0.2s;
}
.cf-pill:hover { border-color: var(--cf-accent); color: var(--cf-accent); background: rgba(255,107,26,0.05); }
</style>

{% schema %}
{ "name": "Quick Filters", "tag": "section" }
{% endschema %}
