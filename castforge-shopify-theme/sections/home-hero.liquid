<section class="cf-home-hero">
  <div class="cf-container">
    <div class="cf-home-hero__content">
      <p class="cf-home-hero__eyebrow">The World's Specialist Resin Model Store</p>
      <h1 class="cf-home-hero__title">Thousands of Resin Kits<br>for Wargamers, Scale Modellers<br>& Collectors</h1>
      <p class="cf-home-hero__sub">Premium resin figures, busts, vehicles, and terrain pieces. Unassembled kits for hobbyists who demand detail.</p>
      <div class="cf-home-hero__buttons">
        <a href="/collections/all" class="cf-btn cf-btn--primary">Shop All Models</a>
        <a href="/collections/new-arrivals" class="cf-btn cf-btn--outline">New Arrivals</a>
        <a href="#cf-categories" class="cf-btn cf-btn--ghost">Browse Categories ↓</a>
      </div>
      <div class="cf-home-hero__stats">
        <div class="cf-home-hero__stat"><strong>13,000+</strong> Models</div>
        <div class="cf-home-hero__stat"><strong>Free</strong> Shipping</div>
        <div class="cf-home-hero__stat"><strong>30-Day</strong> Returns</div>
      </div>
    </div>
  </div>
</section>

<style>
.cf-home-hero {
  position: relative;
  padding: 80px 0 64px;
  background: linear-gradient(135deg, #0a0a0a 0%, #121212 40%, #1a1008 100%);
  overflow: hidden;
}
.cf-home-hero::after {
  content: '';
  position: absolute;
  top: 0; right: 0;
  width: 50%;
  height: 100%;
  background: radial-gradient(ellipse at 80% 50%, rgba(255,107,26,0.08) 0%, transparent 70%);
  pointer-events: none;
}
.cf-home-hero__content { position: relative; z-index: 1; max-width: 700px; }
.cf-home-hero__eyebrow {
  font-family: var(--cf-font-body);
  font-size: 13px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: var(--cf-accent);
  margin-bottom: 16px;
}
.cf-home-hero__title {
  font-family: var(--cf-font-display);
  font-size: 52px;
  line-height: 1.1;
  color: var(--cf-text);
  margin: 0 0 20px;
  letter-spacing: 1px;
}
.cf-home-hero__sub {
  font-size: 17px;
  line-height: 1.6;
  color: var(--cf-text-muted);
  margin-bottom: 32px;
  max-width: 520px;
}
.cf-home-hero__buttons { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 40px; }
.cf-btn {
  display: inline-flex;
  align-items: center;
  padding: 14px 28px;
  border-radius: 6px;
  font-family: var(--cf-font-display);
  font-size: 14px;
  letter-spacing: 1px;
  text-transform: uppercase;
  text-decoration: none;
  cursor: pointer;
  transition: all 0.2s;
}
.cf-btn--primary {
  background: var(--cf-accent);
  color: #fff;
  border: none;
  box-shadow: 0 4px 16px rgba(255,107,26,0.25);
}
.cf-btn--primary:hover { background: var(--cf-accent-hover, #FF8844); transform: translateY(-1px); box-shadow: 0 6px 24px rgba(255,107,26,0.35); }
.cf-btn--outline {
  background: transparent;
  color: var(--cf-text);
  border: 1px solid var(--cf-border);
}
.cf-btn--outline:hover { border-color: var(--cf-accent); color: var(--cf-accent); }
.cf-btn--ghost {
  background: transparent;
  color: var(--cf-text-muted);
  border: none;
  padding: 14px 16px;
}
.cf-btn--ghost:hover { color: var(--cf-accent); }
.cf-home-hero__stats {
  display: flex;
  gap: 32px;
}
.cf-home-hero__stat {
  font-size: 14px;
  color: var(--cf-text-muted);
  font-family: var(--cf-font-body);
}
.cf-home-hero__stat strong {
  color: var(--cf-text);
  font-size: 18px;
  display: block;
  font-family: var(--cf-font-display);
}
@media (max-width: 768px) {
  .cf-home-hero { padding: 48px 0; }
  .cf-home-hero__title { font-size: 32px; }
  .cf-home-hero__stats { gap: 20px; }
  .cf-home-hero__stat strong { font-size: 16px; }
}
</style>

{% schema %}
{ "name": "Homepage Hero", "tag": "section" }
{% endschema %}
