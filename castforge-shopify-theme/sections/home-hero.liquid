{{ 'homepage.css' | asset_url | stylesheet_tag }}

<section class="cf-home-hero">
  <div class="cf-container">
    <div class="cf-home-hero__content">
      <p class="cf-eyebrow">The World's Specialist Resin Model Store</p>
      <h1 class="cf-home-hero__title">Thousands of Resin Kits<br>for Wargamers & Collectors</h1>
      <p class="cf-home-hero__sub">Premium resin figures, busts, vehicles, and terrain pieces. Unassembled kits for hobbyists who demand detail.</p>
      <div class="cf-home-hero__buttons">
        <a href="/collections/all" class="cf-btn cf-btn--primary">Shop All Models</a>
        <a href="/collections/new-arrivals" class="cf-btn cf-btn--outline">New Arrivals</a>
      </div>
      <div class="cf-home-hero__stats">
        <div class="cf-stat"><strong>13,000+</strong><span>Models</span></div>
        <div class="cf-stat"><strong>Free</strong><span>Shipping</span></div>
        <div class="cf-stat"><strong>30-Day</strong><span>Returns</span></div>
      </div>
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded',()=>{
  const obs=new IntersectionObserver(e=>e.forEach(s=>{if(s.isIntersecting){s.target.classList.add('cf-visible');obs.unobserve(s.target)}}),{threshold:0.08});
  document.querySelectorAll('.cf-section').forEach(s=>obs.observe(s));
});
</script>

<style>
.cf-home-hero { padding: 80px 0 60px; background: linear-gradient(135deg, #0a0a0a 0%, #121212 40%, #1a1008 100%); position: relative; overflow: hidden; }
.cf-home-hero::after { content:''; position:absolute; top:0; right:0; width:50%; height:100%; background:radial-gradient(ellipse at 80% 50%, rgba(255,107,26,0.08) 0%, transparent 70%); pointer-events:none; }
.cf-home-hero__content { position:relative; z-index:1; max-width:640px; }
.cf-home-hero__title { font-family:var(--cf-font-display); font-size:48px; line-height:1.1; color:var(--cf-text); margin:0 0 16px; }
.cf-home-hero__sub { font-size:16px; line-height:1.6; color:var(--cf-text-muted); margin-bottom:28px; max-width:480px; }
.cf-home-hero__buttons { display:flex; gap:12px; flex-wrap:wrap; margin-bottom:36px; }
.cf-home-hero__stats { display:flex; gap:28px; }
.cf-stat strong { display:block; font-family:var(--cf-font-display); font-size:18px; color:var(--cf-text); }
.cf-stat span { font-size:13px; color:var(--cf-text-muted); }
@media(max-width:768px){ .cf-home-hero{padding:48px 0 40px;} .cf-home-hero__title{font-size:30px;} .cf-home-hero__stats{gap:16px;} .cf-stat strong{font-size:15px;} }
</style>

{% schema %}
{ "name": "Homepage Hero", "tag": "section" }
{% endschema %}
