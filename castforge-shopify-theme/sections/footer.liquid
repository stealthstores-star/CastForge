<!-- Trust badges above footer -->
<div class="cf-footer-trust">
  <div class="cf-container">
    <div class="cf-footer-trust__grid">
      <span>🔒 Secure Checkout</span>
      <span>🚚 Free Worldwide Shipping</span>
      <span>↩️ 30-Day Returns</span>
      <span>📦 13,000+ Products</span>
    </div>
  </div>
</div>

<footer class="cf-footer">
  <div class="cf-container">
    <div class="cf-footer__grid">
      <div class="cf-footer__col">
        <h4>Shop</h4>
        <a href="/collections/all">All Models</a>
        <a href="/collections/new-arrivals">New Arrivals</a>
        <a href="/collections/best-sellers">Best Sellers</a>
        <a href="/collections/wargaming-infantry">Wargaming</a>
        <a href="/collections/scale-military-vehicles">Scale Models</a>
        <a href="/collections/busts-portraits">Busts</a>
        <a href="/collections/accessories">Accessories</a>
      </div>
      <div class="cf-footer__col">
        <h4>Help</h4>
        <a href="/pages/faq">FAQ</a>
        <a href="/pages/shipping">Shipping Info</a>
        <a href="/pages/returns">Returns Policy</a>
        <a href="/pages/contact">Contact Us</a>
        <a href="/pages/size-guide">Scale Guide</a>
      </div>
      <div class="cf-footer__col">
        <h4>About</h4>
        <a href="/pages/about">Our Story</a>
        <a href="/pages/reviews">Reviews</a>
        <a href="/blogs/news">Blog</a>
        <a href="/pages/terms">Terms of Service</a>
        <a href="/pages/privacy">Privacy Policy</a>
      </div>
      <div class="cf-footer__col">
        <h4>Connect</h4>
        <div class="cf-footer__social">
          <a href="#" aria-label="Instagram">
            <svg viewBox="0 0 24 24" width="20" height="20"><path fill="currentColor" d="M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4a5.8 5.8 0 0 1-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8A5.8 5.8 0 0 1 7.8 2zm-.2 2A3.6 3.6 0 0 0 4 7.6v8.8C4 18.39 5.61 20 7.6 20h8.8a3.6 3.6 0 0 0 3.6-3.6V7.6C20 5.61 18.39 4 16.4 4H7.6zm9.65 1.5a1.25 1.25 0 0 1 1.25 1.25A1.25 1.25 0 0 1 17.25 8 1.25 1.25 0 0 1 16 6.75a1.25 1.25 0 0 1 1.25-1.25zM12 7a5 5 0 0 1 5 5 5 5 0 0 1-5 5 5 5 0 0 1-5-5 5 5 0 0 1 5-5zm0 2a3 3 0 0 0-3 3 3 3 0 0 0 3 3 3 3 0 0 0 3-3 3 3 0 0 0-3-3z"/></svg>
          </a>
          <a href="#" aria-label="TikTok">
            <svg viewBox="0 0 24 24" width="20" height="20"><path fill="currentColor" d="M16.6 5.82s.51.5 0 0A4.278 4.278 0 0 1 15.54 3h-3.09v12.4a2.592 2.592 0 0 1-2.59 2.5c-1.42 0-2.6-1.16-2.6-2.6 0-1.72 1.66-3.01 3.37-2.48V9.66c-3.45-.46-6.47 2.22-6.47 5.64 0 3.33 2.76 5.7 5.69 5.7 3.14 0 5.69-2.55 5.69-5.7V9.01a7.35 7.35 0 0 0 4.3 1.38V7.3s-1.88.09-3.24-1.48z"/></svg>
          </a>
          <a href="#" aria-label="Facebook">
            <svg viewBox="0 0 24 24" width="20" height="20"><path fill="currentColor" d="M12 2.04C6.5 2.04 2 6.53 2 12.06c0 5 3.66 9.15 8.44 9.9v-7H7.9v-2.9h2.54V9.85c0-2.52 1.49-3.93 3.78-3.93 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.78-1.63 1.57v1.88h2.78l-.45 2.9h-2.33v7a10 10 0 0 0 8.44-9.9c0-5.53-4.5-10.02-10-10.02z"/></svg>
          </a>
        </div>
        {% render 'localization-selector' %}
      </div>
    </div>

    <!-- Payment icons -->
    <div class="cf-footer__bottom">
      <div class="cf-footer__payments">
        {% for type in shop.enabled_payment_types %}
          {{ type | payment_type_svg_tag }}
        {% endfor %}
      </div>
      <p class="cf-footer__copy">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
.cf-footer-trust {
  background: var(--cf-bg-card);
  border-top: 1px solid var(--cf-border);
  border-bottom: 1px solid var(--cf-border);
  padding: 16px 0;
}
.cf-footer-trust__grid {
  display: flex;
  justify-content: center;
  gap: 40px;
  font-size: 13px;
  color: var(--cf-text-muted);
  font-family: var(--cf-font-body);
  flex-wrap: wrap;
}
.cf-footer {
  background: var(--cf-bg);
  padding: 48px 0 24px;
}
.cf-footer__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 32px;
  margin-bottom: 40px;
}
.cf-footer__col h4 {
  font-family: var(--cf-font-display);
  font-size: 14px;
  color: var(--cf-accent);
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 16px;
}
.cf-footer__col a {
  display: block;
  font-size: 13px;
  color: var(--cf-text-muted);
  text-decoration: none;
  padding: 3px 0;
  font-family: var(--cf-font-body);
}
.cf-footer__col a:hover { color: var(--cf-text); }
.cf-footer__social { display: flex; gap: 12px; margin-bottom: 16px; }
.cf-footer__social a { color: var(--cf-text-muted); }
.cf-footer__social a:hover { color: var(--cf-accent); }
.cf-footer__bottom {
  border-top: 1px solid var(--cf-border);
  padding-top: 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 12px;
}
.cf-footer__payments { display: flex; gap: 8px; align-items: center; }
.cf-footer__payments svg { height: 24px; width: auto; opacity: 0.6; }
.cf-footer__copy { font-size: 12px; color: var(--cf-text-muted); font-family: var(--cf-font-body); }
@media (max-width: 768px) {
  .cf-footer__grid { grid-template-columns: repeat(2, 1fr); }
  .cf-footer-trust__grid { flex-direction: column; align-items: center; gap: 8px; }
}
</style>

{% schema %}
{ "name": "Footer", "tag": "div" }
{% endschema %}
