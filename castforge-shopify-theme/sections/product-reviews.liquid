<section class="cf-reviews" id="cf-reviews">
  <div class="cf-container">
    <h2 class="cf-section-title">Customer Reviews</h2>

    {% assign reviews_json = product.metafields.reviews.aliexpress %}
    {% assign avg_rating = product.metafields.reviews.average | default: 0 %}
    {% assign review_count = product.metafields.reviews.count | default: 0 %}

    {% if review_count > 0 %}
      <!-- Rating summary -->
      <div class="cf-reviews__summary">
        <div class="cf-reviews__score">
          <span class="cf-reviews__avg">{{ avg_rating }}</span>
          <div class="cf-stars cf-stars--lg">
            {% for i in (1..5) %}
              <svg class="cf-star {% if i <= avg_rating %}cf-star--filled{% endif %}" viewBox="0 0 20 20" width="24" height="24">
                <path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.33L10 13.28l-4.77 2.44.91-5.33L2.27 6.62l5.34-.78z"/>
              </svg>
            {% endfor %}
          </div>
          <span class="cf-reviews__count">Based on {{ review_count }} reviews</span>
        </div>

        <!-- Distribution bars -->
        <div class="cf-reviews__bars">
          {% assign dist = product.metafields.reviews.distribution %}
          {% for i in (1..5) reversed %}
            {% assign star_key = i | append: '' %}
            {% assign star_pct = 0 %}
            {% if dist %}
              {% assign star_count = dist[star_key] | default: 0 %}
              {% assign star_pct = star_count | times: 100 | divided_by: review_count %}
            {% endif %}
            <div class="cf-reviews__bar-row">
              <span class="cf-reviews__bar-label">{{ i }}★</span>
              <div class="cf-reviews__bar-track">
                <div class="cf-reviews__bar-fill" style="width: {{ star_pct }}%"></div>
              </div>
              <span class="cf-reviews__bar-pct">{{ star_pct }}%</span>
            </div>
          {% endfor %}
        </div>
      </div>

      <!-- Individual reviews -->
      <div class="cf-reviews__list" id="cf-reviews-list">
        {% if reviews_json %}
          {% assign reviews = reviews_json | parse_json %}
          {% for review in reviews limit: 12 %}
            <div class="cf-review-card {% if forloop.index > 3 %}cf-review--hidden{% endif %}">
              <div class="cf-review-card__header">
                <div class="cf-stars cf-stars--sm">
                  {% for s in (1..5) %}
                    <svg class="cf-star {% if s <= review.rating %}cf-star--filled{% endif %}" viewBox="0 0 20 20" width="14" height="14">
                      <path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.33L10 13.28l-4.77 2.44.91-5.33L2.27 6.62l5.34-.78z"/>
                    </svg>
                  {% endfor %}
                </div>
                <span class="cf-review-card__name">{{ review.name }}</span>
                <span class="cf-review-card__date">{{ review.date }}</span>
              </div>
              <p class="cf-review-card__text">{{ review.text }}</p>
              {% if review.images %}
                <div class="cf-review-card__images">
                  {% for img in review.images limit: 3 %}
                    <img src="{{ img }}" alt="Review photo" width="80" height="80" loading="lazy">
                  {% endfor %}
                </div>
              {% endif %}
            </div>
          {% endfor %}
        {% endif %}
      </div>

      {% if review_count > 3 %}
        <button class="cf-reviews__load-more" id="cf-load-reviews">
          Show all {{ review_count }} reviews
        </button>
      {% endif %}

    {% else %}
      <!-- No reviews -->
      <div class="cf-reviews__empty">
        <p>No reviews yet — be the first to share your experience!</p>
        <div class="cf-stars cf-stars--lg">
          {% for i in (1..5) %}
            <svg class="cf-star" viewBox="0 0 20 20" width="28" height="28">
              <path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.33L10 13.28l-4.77 2.44.91-5.33L2.27 6.62l5.34-.78z"/>
            </svg>
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>
</section>

<script>
document.getElementById('cf-load-reviews')?.addEventListener('click', function() {
  document.querySelectorAll('.cf-review--hidden').forEach(r => r.classList.remove('cf-review--hidden'));
  this.hidden = true;
});
</script>

{% schema %}
{
  "name": "Product Reviews",
  "tag": "section",
  "class": "cf-section-reviews"
}
{% endschema %}
