<section class="cf-section cf-section--alt">
  <div class="cf-container" style="text-align:center;">
    <p class="cf-eyebrow">Stay in the Loop</p>
    <h2 class="cf-h2">Get 10% Off Your First Order</h2>
    <p style="color:var(--cf-text-muted);margin-bottom:24px;font-size:15px;">Join 4,000+ collectors. New arrivals, painting tips, and exclusive deals.</p>
    {% form 'customer' %}
      {{ form.errors | default_errors }}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div style="display:flex;gap:8px;max-width:480px;margin:0 auto;">
        <input type="email" name="contact[email]" placeholder="Enter your email" required style="flex:1;padding:14px 16px;background:var(--cf-bg-card);border:1px solid var(--cf-border);border-radius:6px;color:var(--cf-text);font-size:14px;font-family:var(--cf-font-body);">
        <button type="submit" class="cf-btn cf-btn--primary">Subscribe</button>
      </div>
    {% endform %}
  </div>
</section>
{% schema %}
{ "name": "Newsletter", "tag": "section" }
{% endschema %}
