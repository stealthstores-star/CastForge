<section class="cf-recently-viewed" id="cf-recently-viewed" style="display:none">
  <div class="cf-container">
    <h2 class="cf-section-title">Recently Viewed</h2>
    <div class="cf-related__grid" id="cf-rv-grid"></div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', () => {
  try {
    const rv = JSON.parse(localStorage.getItem('cf_recently_viewed') || '[]');
    const currentId = {{ product.id }};
    const others = rv.filter(p => p.id !== currentId).slice(0, 4);
    if (others.length === 0) return;

    const grid = document.getElementById('cf-rv-grid');
    const section = document.getElementById('cf-recently-viewed');
    others.forEach(p => {
      const card = document.createElement('a');
      card.href = p.url;
      card.className = 'cf-product-card';
      card.innerHTML = `
        <div class="cf-product-card__img">
          ${p.image ? `<img src="${p.image}" alt="${p.title}" width="400" height="400" loading="lazy">` : ''}
        </div>
        <h3 class="cf-product-card__title">${p.title.substring(0, 60)}</h3>
        <span class="cf-product-card__price">${Shopify.formatMoney ? Shopify.formatMoney(p.price) : ''}</span>
      `;
      grid.appendChild(card);
    });
    section.style.display = '';
  } catch(e) {}
});
</script>

{% schema %}
{
  "name": "Recently Viewed",
  "tag": "section",
  "class": "cf-section-rv"
}
{% endschema %}
