{{ 'header.css' | asset_url | stylesheet_tag }}

<header class="cf-header">
  <div class="cf-container">
    <div class="cf-header__inner">
      <button class="cf-hamburger" id="cf-hamburger" aria-label="Menu"><span></span><span></span><span></span></button>
      <a href="/" class="cf-header__logo">
        {% if settings.logo %}<img src="{{ settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" height="36">
        {% else %}<span class="cf-logo-text">CASTFORGE</span>{% endif %}
      </a>
      <nav class="cf-nav">
        <a href="/collections/all" class="cf-nav__link">Shop All</a>
        <a href="/collections/new-arrivals" class="cf-nav__link">New Arrivals</a>
        <a href="/collections/best-sellers" class="cf-nav__link">Best Sellers</a>
        <a href="/collections/accessories" class="cf-nav__link">Accessories</a>
      </nav>
      <div class="cf-header__right">
        {% render 'localization-selector' %}
        <button class="cf-header__icon" aria-label="Search" onclick="openSearchOverlay()"><svg viewBox="0 0 24 24" width="20" height="20"><path fill="currentColor" d="M15.5 14h-.79l-.28-.27A6.47 6.47 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg></button>
        <a href="/account" class="cf-header__icon" aria-label="Account"><svg viewBox="0 0 24 24" width="20" height="20"><path fill="currentColor" d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg></a>
        <a href="/cart" class="cf-header__icon" aria-label="Cart"><svg viewBox="0 0 24 24" width="20" height="20"><path fill="currentColor" d="M7 18c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49A1 1 0 0020 4H5.21l-.94-2H1zm16 16c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/></svg>{% if cart.item_count > 0 %}<span class="cf-cart-badge">{{ cart.item_count }}</span>{% endif %}</a>
      </div>
    </div>
  </div>
</header>

<div class="cf-mobile-nav" id="cf-mobile-nav">
  <div class="cf-mobile-nav__header"><span class="cf-logo-text">CASTFORGE</span><button class="cf-mobile-nav__close" id="cf-mobile-close">✕</button></div>
  <nav class="cf-mobile-nav__links">
    <a href="/collections/all">Shop All</a><a href="/collections/new-arrivals">New Arrivals</a><a href="/collections/best-sellers">Best Sellers</a>
    <a href="/collections/wargaming-infantry">Wargaming</a><a href="/collections/scale-military-vehicles">Scale Models</a>
    <a href="/collections/busts-portraits">Busts</a><a href="/collections/fantasy-warriors">Fantasy</a>
    <a href="/collections/scifi-figures">Sci-Fi</a><a href="/collections/anime-characters">Anime</a>
    <a href="/collections/terrain-buildings-ruins">Terrain</a><a href="/collections/accessories">Accessories</a>
  </nav>
</div>
<div class="cf-overlay" id="cf-overlay"></div>

<script>
(function(){
  const h=document.getElementById('cf-hamburger'),n=document.getElementById('cf-mobile-nav'),o=document.getElementById('cf-overlay'),c=document.getElementById('cf-mobile-close');
  function t(v){n.classList.toggle('is-open',v);o.classList.toggle('is-visible',v);document.body.style.overflow=v?'hidden':'';}
  h?.addEventListener('click',()=>t(true));c?.addEventListener('click',()=>t(false));o?.addEventListener('click',()=>t(false));
})();
</script>
{% schema %}
{ "name": "Header", "tag": "div", "class": "cf-header-wrap" }
{% endschema %}
