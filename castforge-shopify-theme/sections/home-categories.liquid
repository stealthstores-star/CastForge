<section class="cf-categories cf-section" id="cf-categories">
  <div class="cf-container">
    <h2 class="cf-section-title">Shop by Category</h2>
    <div class="cf-categories__grid">
      {%- assign cat_handles = "wargaming-heroes-characters,wargaming-infantry,scale-military-vehicles,scale-aircraft,scale-ships-naval,busts-portraits,fantasy-warriors,anime-characters,scifi-figures,accessories,terrain-buildings-ruins,scale-cars-motorcycles" | split: "," -%}
      {%- assign cat_names = "Wargaming Heroes,Wargaming Infantry,Military Vehicles,Aircraft,Ships & Naval,Busts & Portraits,Fantasy Warriors,Anime Characters,Sci-Fi Figures,Accessories,Terrain & Buildings,Cars & Motorcycles" | split: "," -%}
      {%- for handle in cat_handles -%}
        {%- assign col = collections[handle] -%}
        {%- assign name = cat_names[forloop.index0] -%}
        {%- if col -%}
          {%- comment -%} Pick best image: collection image → first product image → placeholder {%- endcomment -%}
          {%- if col.image -%}
            {%- assign card_img = col.image | image_url: width: 600 -%}
          {%- elsif col.products.first.featured_image -%}
            {%- assign card_img = col.products.first.featured_image | image_url: width: 600 -%}
          {%- else -%}
            {%- assign card_img = "" -%}
          {%- endif -%}
          <a href="{{ col.url }}" class="cf-cat-card">
            <div class="cf-cat-card__img">
              {%- if card_img != "" -%}
                <img src="{{ card_img }}" alt="{{ name }}" width="600" height="600" loading="lazy">
              {%- endif -%}
              <div class="cf-cat-card__overlay">
                <h3 class="cf-cat-card__name">{{ name }}</h3>
                <span class="cf-cat-card__count">{{ col.products_count }} models</span>
              </div>
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
.cf-categories__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
}
.cf-cat-card {
  display: block;
  text-decoration: none;
  border-radius: 10px;
  overflow: hidden;
  border: 2px solid transparent;
  transition: border-color 0.3s, transform 0.3s, box-shadow 0.3s;
}
.cf-cat-card:hover {
  border-color: var(--cf-accent, #FF6B1A);
  transform: translateY(-4px);
  box-shadow: 0 8px 32px rgba(255,107,26,0.2);
}
.cf-cat-card__img {
  position: relative;
  aspect-ratio: 1 / 1;
  background: #111;
  overflow: hidden;
}
.cf-cat-card__img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s;
}
.cf-cat-card:hover .cf-cat-card__img img { transform: scale(1.08); }
.cf-cat-card__overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20px 16px 16px;
  background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.4) 60%, transparent 100%);
}
.cf-cat-card__name {
  font-family: var(--cf-font-display, 'Anton', sans-serif);
  font-size: 16px;
  letter-spacing: 0.5px;
  color: #fff;
  margin: 0;
  text-transform: uppercase;
}
.cf-cat-card__count {
  font-family: var(--cf-font-body, 'Inter', sans-serif);
  font-size: 12px;
  color: rgba(255,255,255,0.7);
}
@media (max-width: 768px) {
  .cf-categories__grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
  .cf-cat-card__name { font-size: 14px; }
}
</style>

{% schema %}
{ "name": "Shop by Category", "tag": "section" }
{% endschema %}
