<section class="cf-section cf-section--alt" id="cf-categories">
  <div class="cf-container">
    <p class="cf-eyebrow">Explore Our Range</p>
    <h2 class="cf-h2">Shop by Category</h2>
    <div class="cf-cat-grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link }}" class="cf-cat-card" {{ block.shopify_attributes }}>
          <div class="cf-cat-card__img">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.title }}" width="600" height="600" loading="lazy">
            {%- else -%}
              <img src="https://images.unsplash.com/photo-1612287230202-1ff1d85d1bdf?w=600&h=600&fit=crop" alt="{{ block.settings.title }}" width="600" height="600" loading="lazy">
            {%- endif -%}
          </div>
          <div class="cf-cat-card__overlay">
            <h3>{{ block.settings.title }}</h3>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
.cf-cat-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; }
.cf-cat-card { display: block; position: relative; border-radius: 10px; overflow: hidden; text-decoration: none; border: 2px solid transparent; transition: border-color 0.3s, transform 0.3s, box-shadow 0.3s; }
.cf-cat-card:hover { border-color: var(--cf-accent); transform: translateY(-4px); box-shadow: 0 8px 32px rgba(255,107,26,0.2); }
.cf-cat-card__img { aspect-ratio: 1/1; background: #111; overflow: hidden; }
.cf-cat-card__img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s; }
.cf-cat-card:hover .cf-cat-card__img img { transform: scale(1.08); }
.cf-cat-card__overlay { position: absolute; bottom: 0; left: 0; right: 0; padding: 24px 16px 16px; background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.5) 50%, transparent 100%); }
.cf-cat-card__overlay h3 { font-family: var(--cf-font-display); font-size: 15px; color: #fff; margin: 0; text-transform: uppercase; letter-spacing: 0.5px; }
@media (max-width: 768px) { .cf-cat-grid { grid-template-columns: repeat(2, 1fr); gap: 8px; } .cf-cat-card__overlay h3 { font-size: 13px; } .cf-cat-card__overlay { padding: 16px 10px 10px; } }
</style>

{% schema %}
{
  "name": "Shop by Category",
  "tag": "section",
  "max_blocks": 16,
  "blocks": [
    {
      "type": "category",
      "name": "Category Card",
      "settings": [
        { "type": "text", "id": "title", "label": "Category Name", "default": "Category" },
        { "type": "url", "id": "link", "label": "Collection URL" },
        { "type": "image_picker", "id": "image", "label": "Category Thumbnail" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by Category",
      "blocks": [
        { "type": "category", "settings": { "title": "Wargaming Heroes", "link": "/collections/wargaming-heroes-characters" } },
        { "type": "category", "settings": { "title": "Wargaming Infantry", "link": "/collections/wargaming-infantry" } },
        { "type": "category", "settings": { "title": "Military Vehicles", "link": "/collections/scale-military-vehicles" } },
        { "type": "category", "settings": { "title": "Aircraft", "link": "/collections/scale-aircraft" } },
        { "type": "category", "settings": { "title": "Ships & Naval", "link": "/collections/scale-ships-naval" } },
        { "type": "category", "settings": { "title": "Busts & Portraits", "link": "/collections/busts-portraits" } },
        { "type": "category", "settings": { "title": "Fantasy Warriors", "link": "/collections/fantasy-warriors" } },
        { "type": "category", "settings": { "title": "Sci-Fi Figures", "link": "/collections/scifi-figures" } },
        { "type": "category", "settings": { "title": "Anime Characters", "link": "/collections/anime-characters" } },
        { "type": "category", "settings": { "title": "Terrain & Buildings", "link": "/collections/terrain-buildings-ruins" } },
        { "type": "category", "settings": { "title": "Cars & Motorcycles", "link": "/collections/scale-cars-motorcycles" } },
        { "type": "category", "settings": { "title": "Accessories", "link": "/collections/accessories" } }
      ]
    }
  ]
}
{% endschema %}
