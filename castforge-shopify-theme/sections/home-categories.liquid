<section class="cf-section cf-section--alt" id="cf-categories">
  <div class="cf-container">
    <p class="cf-eyebrow">Explore Our Range</p>
    <h2 class="cf-h2">Shop by Category</h2>
    <div class="cf-cat-grid">
      {%- assign cat_handles = "wargaming-heroes-characters,wargaming-infantry,scale-military-vehicles,scale-aircraft,scale-ships-naval,busts-portraits,fantasy-warriors,scifi-figures,anime-characters,terrain-buildings-ruins,scale-cars-motorcycles,accessories" | split: "," -%}
      {%- for handle in cat_handles -%}
        {%- assign col = collections[handle] -%}
        <a href="/collections/{{ handle }}" class="cf-cat-card">
          {%- if col.image -%}
            <img src="{{ col.image | image_url: width: 600 }}" alt="{{ col.title }}" width="600" height="600" loading="lazy">
          {%- elsif col.products.first.featured_image -%}
            <img src="{{ col.products.first.featured_image | image_url: width: 600 }}" alt="{{ col.title }}" width="600" height="600" loading="lazy">
          {%- else -%}
            <div class="cf-cat-card__ph"></div>
          {%- endif -%}
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>
<style>
.cf-cat-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:10px; }
.cf-cat-card { display:block; border-radius:8px; overflow:hidden; border:2px solid transparent; transition:border-color 0.3s, transform 0.3s, box-shadow 0.3s; }
.cf-cat-card:hover { border-color:var(--cf-accent); transform:translateY(-3px); box-shadow:0 8px 28px rgba(255,107,26,0.2); }
.cf-cat-card img { display:block; width:100%; aspect-ratio:1/1; object-fit:cover; }
.cf-cat-card__ph { aspect-ratio:1/1; background:linear-gradient(135deg,#111,#1a1a1a); }
@media(max-width:768px){ .cf-cat-grid{grid-template-columns:repeat(2,1fr);gap:8px;} }
</style>
{% schema %}
{ "name": "Shop by Category", "tag": "section" }
{% endschema %}
