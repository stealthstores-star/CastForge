<section class="cf-why cf-section">
  <div class="cf-container">
    <h2 class="cf-section-title">Why CastForge</h2>
    <div class="cf-why__grid">
      <div class="cf-why__card">
        <svg viewBox="0 0 24 24" width="40" height="40"><path fill="#FF6B1A" d="M4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm16-4H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-1 9H9v-2h10v2zm-4 4H9v-2h6v2zm4-8H9V5h10v2z"/></svg>
        <h3>13,000+ Models</h3>
        <p>The largest curated resin model catalogue online. From 28mm wargaming to 1/35 military.</p>
      </div>
      <div class="cf-why__card">
        <svg viewBox="0 0 24 24" width="40" height="40"><path fill="#FF6B1A" d="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-3-4zM6 18.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm13.5-9l1.96 2.5H17V9.5h2.5zm-1.5 9c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/></svg>
        <h3>US, EU & UK Warehouses</h3>
        <p>Free worldwide shipping from local warehouses. Most orders arrive within 5-7 business days.</p>
      </div>
      <div class="cf-why__card">
        <svg viewBox="0 0 24 24" width="40" height="40"><path fill="#FF6B1A" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
        <h3>30-Day Returns</h3>
        <p>Not happy? Full refund within 30 days. Damaged items replaced free — no return needed.</p>
      </div>
      <div class="cf-why__card">
        <svg viewBox="0 0 24 24" width="40" height="40"><path fill="#FF6B1A" d="M12 1l3.22 3.22h4.56v4.56L23 12l-3.22 3.22v4.56h-4.56L12 23l-3.22-3.22H4.22v-4.56L1 12l3.22-3.22V4.22h4.56L12 1zm0 4c-3.87 0-7 3.13-7 7s3.13 7 7 7 7-3.13 7-7-3.13-7-7-7zm0 2c2.76 0 5 2.24 5 5s-2.24 5-5 5-5-2.24-5-5 2.24-5 5-5z"/></svg>
        <h3>Expert Curation</h3>
        <p>Every model hand-selected for detail quality. We reject 60% of what we evaluate.</p>
      </div>
    </div>
  </div>
</section>

<style>
.cf-why { padding: 64px 0; background: var(--cf-bg-card); border-top: 1px solid var(--cf-border); }
.cf-why__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
.cf-why__card {
  text-align: center;
  padding: 24px 16px;
  font-family: var(--cf-font-body);
}
.cf-why__card h3 { font-size: 16px; color: var(--cf-text); margin: 16px 0 8px; font-weight: 700; }
.cf-why__card p { font-size: 13px; color: var(--cf-text-muted); line-height: 1.6; }
@media (max-width: 768px) { .cf-why__grid { grid-template-columns: repeat(2, 1fr); } }
</style>

{% schema %}
{ "name": "Why CastForge", "tag": "section" }
{% endschema %}
